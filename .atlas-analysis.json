  "keyFeatures": [
    "In-memory and thread-local cache engines with TTL and size regulation",
    "Remote cache backends for Redis and Memcached",
    "Custom JSON serialization/deserialization supporting datetime, date, list, tuple, and dict types",
    "Pickle-based binary serialization",
    "MD5 hash builder for arbitrary Python objects",
    "Dynamic module import utilities",
    "Configurable structured logging with Logstash support",
    "ZIP file extractor abstraction",
    "Cache decorators for functions (@thread_local_cache, @in_memory_local_cache)"
  ],
  "publicApiSurface": [
    "InMemoryCacheEngine.get(key)",
    "InMemoryCacheEngine.set(key, value, timeout, size)",
    "InMemoryCacheEngine.delete(key)",
    "InMemoryCacheEngine.exists(key)",
    "InMemoryCacheEngine.clear()",
    "ThreadCacheEngine.get(key)",
    "ThreadCacheEngine.set(key, value, timeout, size)",
    "ThreadCacheEngine.delete(key)",
    "ThreadCacheEngine.exists(key)",
    "ThreadCacheEngine.clear()",
